{
  "name": "@hellodriver/backend",
  "version": "0.0.1",
  "description": "HelloDriver Fastify API",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "NODE_ENV=development node --watch src/index.ts --loader tsx",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:integration": "vitest --run --config vitest.config.integration.ts",
    "lint": "eslint src",
    "format": "prettier --write src"
  },
  "dependencies": {
    "fastify": "^4.25.2",
    "fastify-cors": "^8.4.2",
    "fastify-jwt": "^7.2.4",
    "fastify-plugin": "^4.5.1",
    "pg": "^8.11.3",
    "redis": "^4.6.12",
    "bullmq": "^5.2.6",
    "socket.io": "^4.7.2",
    "@supabase/supabase-js": "^2.38.4",
    "zod": "^3.22.4",
    "dotenv": "^16.3.1",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/pg": "^8.11.2",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "vitest": "^1.1.0",
    "@vitest/ui": "^1.1.0",
    "supertest": "^6.3.3",
    "@types/supertest": "^6.0.2",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
