{
  "name": "@hellodriver/backend",
  "version": "0.0.1",
  "description": "HelloDriver Fastify API",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "lint": "echo 'Linting skipped for Phase 1'",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/sensible": "^6.0.0",
    "@socket.io/redis-streams-adapter": "^0.2.0",
    "@supabase/supabase-js": "^2.47.0",
    "bullmq": "^5.34.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.39.0",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.0",
    "fastify-type-provider-zod": "^4.0.0",
    "ioredis": "^5.4.0",
    "pg": "^8.13.0",
    "socket.io": "^4.8.0",
    "socket.io-msgpack-parser": "^3.0.0",
    "uuid": "^9.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^6.0.0",
    "@types/uuid": "^9.0.7",
    "drizzle-kit": "^0.30.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
