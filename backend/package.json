{
  "name": "@hellodriver/backend",
  "version": "0.0.1",
  "description": "HelloDriver Fastify API",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "NODE_ENV=development node --watch src/index.ts --loader tsx",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:integration": "vitest --run --config vitest.config.integration.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint src",
    "format": "prettier --write src"
  },
  "dependencies": {
    "fastify": "latest",
    "@fastify/cors": "latest",
    "@fastify/jwt": "latest",
    "@fastify/multipart": "latest",
    "fastify-plugin": "latest",
    "pg": "latest",
    "drizzle-orm": "latest",
    "redis": "latest",
    "bullmq": "latest",
    "socket.io": "latest",
    "@supabase/supabase-js": "latest",
    "zod": "latest",
    "dotenv": "latest",
    "pino": "latest",
    "pino-pretty": "latest",
    "uuid": "latest"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/pg": "^8.11.2",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "vitest": "^1.1.0",
    "@vitest/ui": "^1.1.0",
    "supertest": "^6.3.3",
    "@types/supertest": "^6.0.2",
    "drizzle-kit": "latest",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
