# Database
DATABASE_URL=postgresql://user:password@localhost:5432/hellodriver

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# SMS Provider (Custom: Airtel Money API for Gabon OTP)
# For development: OTP codes are logged to console (NODE_ENV=development)
# For production: integrate with Airtel Money API
# Get from https://developers.airtel.africa
AIRTEL_API_KEY=your-airtel-api-key

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
